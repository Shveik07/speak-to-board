# Telegram Bot Token (от @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_USERNAME=speak_to_board_bot

# Vosk модель (путь относительно проекта)
VOSK_MODEL_PATH=models/vosk-model

# Trello API (полученные ранее)
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_API_TOKEN=your_trello_api_token_here
TRELLO_LIST_ID=your_list_id_here

# FFMPEG_PATH переменная окружения (для Windows)
FFMPEG_PATH=C:\Program Files (x86)\Плагин фиксации действий пользователя\ffmpeg\ffmpeg.exe

# Для будущих расширений (опционально)
LOG_LEVEL=INFO